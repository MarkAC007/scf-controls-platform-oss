# =============================================================================
# SCF Controls Platform — environment template
#
# Quick start:
#   cp .env.example .env
#   # edit the REQUIRED values below, then:
#   docker compose --profile init run --rm catalog-importer   # one-time catalogue import
#   docker compose up -d
#
# The defaults below are enough to boot the stack locally for evaluation.
# CHANGE every value marked REQUIRED before exposing this to a network.
# Never commit your filled-in .env — only this .env.example is tracked.
# =============================================================================

# ---- REQUIRED -------------------------------------------------------------
# Postgres password. Compose builds DATABASE_URL from this:
#   postgresql+asyncpg://cg:${DB_PASSWORD}@postgres:5432/cg_scf
# Use a strong value in any shared/production environment.
DB_PASSWORD=changeme-postgres

# Backend API key (master key for programmatic access). Generate a real random
# value for anything beyond local eval, e.g.:  openssl rand -hex 32
API_KEY=changeme-generate-a-real-api-key

# ---- CORE -----------------------------------------------------------------
# Logging verbosity: debug | info | warning | error
LOG_LEVEL=info

# Deployment environment: development | staging | production
# Ships as 'production' so a default deploy is safe. Only set 'development' on a
# trusted local machine — it enables debug error detail and uvicorn auto-reload.
ENVIRONMENT=production

# Self-hosted single-tenant mode (OSS). Set to 1 to let the master API_KEY act as
# admin on your single organisation — this is how the self-hosted UI authenticates.
# SAFE only for a genuine single-tenant deploy: the backend refuses it at startup if
# more than one organisation or human member exists. Leave UNSET / 0 for any
# multi-tenant or hosted deployment. (issue #662)
OSS_SINGLE_TENANT=1

# Version labels surfaced on the /version endpoint. CATALOG_VERSION is the
# fallback used when the catalogue git metadata is not mounted (the default for
# this Docker-only release) — set it to match the SCF workbook you imported.
CATALOG_VERSION=2025.4
# Fallback only — the real version is read from webclient/package.json (source of truth
# for the vX.Y.Z GitHub Release tags). Keep this aligned with it.
PLATFORM_VERSION=0.10.0

# ---- HOST PORTS (optional) ------------------------------------------------
# Host-side published ports, remappable when a default is already taken on your
# host (8000 and 9000 are popular defaults for other tools). Container-side
# ports never change. For deeper compose customisation, prefer a
# docker-compose.override.yml overlay (see UPGRADING.md) so `git pull` stays clean.
# BACKEND_PORT=8000        # FastAPI backend (http://localhost:8000)
# FRONTEND_PORT=5173       # Web UI (http://localhost:5173)
# MINIO_PORT=9000          # MinIO S3 API — presigned evidence up/downloads.
#                          # EVIDENCE_PUBLIC_ENDPOINT's default follows this
#                          # automatically for same-machine installs.
# MINIO_CONSOLE_PORT=9001  # MinIO web console
# POSTGRES_PORT=5432       # Postgres — published on 127.0.0.1 ONLY (local admin
#                          # tools). The app uses the internal docker network;
#                          # expose it wider only via a deliberate overlay.
# KEYCLOAK_PORT=8081       # Bundled Keycloak (--profile idp); keep KC_HOSTNAME in sync.

# ---- PLATFORM UPGRADES ----------------------------------------------------
# The backend polls the public GitHub Releases API once a day and surfaces an
# "update available" signal to platform admins on the Version Information panel.
# It is OUTBOUND-ONLY (no telemetry, no inbound access) and defaults to ON.
# Set to false / 0 to opt out entirely — recommended for air-gapped installs.
SCF_UPDATE_CHECK=true

# Backup acknowledgement for the backend migration guard. Normally you never set
# this: run ./scripts/upgrade.sh vX.Y.Z, which backs up BOTH data stores first
# and sets the ack for you. Set it manually (to the target version, e.g. 0.9.0,
# or "any") ONLY if you run a bare `docker compose up --build` and have your own
# verified backup — it lets the startup migration proceed without the script.
# SCF_MIGRATE_ACK=

# ---- AUTHENTICATION (Google OAuth — optional) -----------------------------
# Leave GOOGLE_AUTH_ENABLED=false to run with API-key auth only.
# If you enable it, set the client ID (backend + frontend must match).
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
# Frontend build-time copies of the above (baked into the bundle at build):
VITE_GOOGLE_AUTH_ENABLED=false
# Set true to use redirect-based OIDC sign-in (bundled Keycloak profile or BYO IdP).
# Takes precedence over Google sign-in in the web client. See the Bundled Identity
# Provider section below for the matching backend OIDC_* configuration.
VITE_OIDC_ENABLED=false
VITE_GOOGLE_CLIENT_ID=
# API key the frontend uses to call the backend (typically the same as API_KEY):
VITE_API_KEY=changeme-generate-a-real-api-key

# ---- Bundled Identity Provider (optional, compose profile "idp") -----------
# Two ways to get OIDC/SSO:
#
#   1. BUNDLED Keycloak — run the extra profile; it stores realm/users in the
#      existing postgres and auto-imports idp/scf-realm.json:
#          docker compose --profile idp up -d
#      The variables in THIS block are then required: the idp containers assert
#      them at startup and exit loudly if empty (KC_ADMIN_* have no static default).
#
#   2. BRING YOUR OWN external OIDC provider (Okta, Entra, Auth0, Google, …) —
#      do NOT start the "idp" profile; just set the OIDC_* values below to your
#      provider. The backend reads OIDC_* regardless of the profile.
#
# --- Keycloak admin (REQUIRED when using --profile idp; no defaults) --------
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme-keycloak-admin
# Public base URL Keycloak advertises. Stays COMMENTED OUT for the default
# same-machine install: when unset, docker-compose.yml defaults it to
# http://localhost:<KEYCLOAK_PORT>, so it follows a remapped KEYCLOAK_PORT
# automatically. Uncomment and set it when the stack runs on a REMOTE host
# (use an address your browser can reach, e.g. http://my-docker-host:8081) or
# behind a reverse proxy (public https URL + KC_PROXY_HEADERS=xforwarded on the
# keycloak service).
# KC_HOSTNAME=http://localhost:8081
# If set, idp-init creates this Keycloak user on first boot with a RANDOM
# temporary password printed ONCE to the idp-init container logs. Leave blank to
# skip. (`docker compose --profile idp logs idp-init` to read it.)
BOOTSTRAP_ADMIN_EMAIL=
#
# --- OIDC wiring (backend). ISSUER vs DISCOVERY_URL is the classic footgun: ---
#   OIDC_ISSUER        = the PUBLIC issuer, byte-for-byte identical to the `iss`
#                        claim in tokens and to what the browser is redirected to.
#                        For the bundled Keycloak on the dev stack this is the
#                        host-visible URL below.
#   OIDC_DISCOVERY_URL = the INTERNAL realm base URL the BACKEND fetches
#                        server-side to load provider metadata/JWKS. Inside docker
#                        that is the internal service DNS name
#                        (http://keycloak:8080/realms/scf), which is NOT reachable
#                        from the browser. Set this to the BARE realm base only —
#                        the backend's get_discovery() appends
#                        `/.well-known/openid-configuration` itself, so DO NOT
#                        include that suffix here or you get a doubled path -> 404.
#                        If you set DISCOVERY_URL to the internal name but leave
#                        ISSUER as the internal name too, tokens minted with a
#                        public `iss` will fail validation behind a reverse proxy —
#                        keep ISSUER public, DISCOVERY internal.
#
# REMOTE-HOST DEPLOYS: the localhost values below only work when your browser
# runs on the Docker host itself. On a remote host, set OIDC_ISSUER and
# OIDC_REDIRECT_URI (and KC_HOSTNAME above) to an address YOUR BROWSER can
# reach (e.g. http://my-docker-host:8081/realms/scf) — and if you remapped
# KEYCLOAK_PORT or FRONTEND_PORT, use those ports here. OIDC_DISCOVERY_URL
# stays internal and never changes.
OIDC_ISSUER=http://localhost:8081/realms/scf
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/scf
OIDC_CLIENT_ID=scf-platform
# Confidential client secret. Generate your own (openssl rand -hex 32); idp-init
# writes THIS value into Keycloak at boot, so the secret lives only here in env.
OIDC_CLIENT_SECRET=changeme-generate-a-real-oidc-secret
# Redirect URI registered for the client. The browser loads the frontend on 5173
# and Vite proxies /api -> backend, so the URI deployers actually use on the dev
# stack is the 5173 one below (it reaches the backend's /api/auth/callback through
# the proxy). http://localhost:8000/api/auth/callback (backend direct) is also a
# registered redirect for callers that hit the API port directly.
OIDC_REDIRECT_URI=http://localhost:5173/api/auth/callback

# ---- EMAIL NOTIFICATIONS (Resend — optional) ------------------------------
# Leave RESEND_API_KEY blank to disable outbound email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@example.com
# Public URL of the frontend, used in links inside notification emails:
APP_URL=http://localhost:5173

# ---- EVIDENCE STORAGE -----------------------------------------------------
# By DEFAULT the stack uses the bundled MinIO container (S3-compatible) so you
# need no cloud account. The values below match the MinIO service in
# docker-compose.yml — change the password for anything beyond local eval.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme-minio-password
EVIDENCE_BUCKET=evidence
# S3 credentials the backend uses — must match the MINIO_ROOT_* values above:
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme-minio-password
AWS_DEFAULT_REGION=eu-west-1
# Internal endpoint the backend/worker use; public endpoint the browser uses for
# presigned upload/download URLs. Leave as-is for the bundled MinIO.
#
# EVIDENCE_PUBLIC_ENDPOINT stays COMMENTED OUT for the default same-machine
# install: when unset, docker-compose.yml defaults it to
# http://localhost:<MINIO_PORT>, so it follows a remapped MINIO_PORT
# automatically. Setting it here overrides that auto-follow.
#
# REMOTE-HOST DEPLOYS: uncomment and set it to an address YOUR BROWSER can
# reach. If the stack runs on a different machine than the one you browse
# from, localhost won't resolve — use the host's IP or DNS name (e.g.
# http://my-docker-host:9000) or evidence upload/download will fail silently.
AWS_ENDPOINT_URL=http://minio:9000
# EVIDENCE_PUBLIC_ENDPOINT=http://localhost:9000
#
# To use AWS S3 instead of MinIO: set EVIDENCE_BUCKET to your real bucket, set
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY to real credentials, and set BOTH
# AWS_ENDPOINT_URL= and EVIDENCE_PUBLIC_ENDPOINT= explicitly EMPTY (uncomment
# EVIDENCE_PUBLIC_ENDPOINT above and leave it blank; empty = use AWS S3 directly).
#
# To use Azure Blob instead: set the two values below (takes priority over S3).
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
EVIDENCE_CONTAINER=evidence

# ---- AI ASSESSMENT (Anthropic — optional) ---------------------------------
# Enables AI-assisted evidence/window assessment. Leave blank to disable.
ANTHROPIC_API_KEY=

# ---- VENDOR RESEARCH (optional) -------------------------------------------
# Third-party breach / vulnerability lookups used by vendor research tasks.
HIBP_API_KEY=
NVD_API_KEY=

# ---- TELEMETRY (optional) -------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---- CATALOGUE IMPORTER (optional) ----------------------------------------
# Path to your SCF Excel workbook for `docker compose --profile init run
# catalog-importer`. Defaults to ./catalog-source/scf.xlsx if unset.
# SCF_XLSX=./catalog-source/scf.xlsx
