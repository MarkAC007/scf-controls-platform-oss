# Dockerfile for CG CCF Frontend (Development)
# Uses Vite dev server for local development with hot reload

FROM node:20-alpine

WORKDIR /app

# Copy package files including lockfile for reproducible installs
COPY webclient/package*.json ./

# Install dependencies from lockfile; add missing linux-x64 rollup binary
RUN npm ci && \
    npm ls @rollup/rollup-linux-x64-gnu || npm install @rollup/rollup-linux-x64-gnu --save-optional --ignore-scripts && \
    npm cache clean --force

# Copy source code
COPY webclient/ ./

# Build arguments (only for Google Auth, not API URL)
ARG VITE_GOOGLE_AUTH_ENABLED
ARG VITE_GOOGLE_CLIENT_ID
ARG VITE_API_KEY
ARG VITE_DEBUG_API

# Set as environment variables for Vite
ENV VITE_GOOGLE_AUTH_ENABLED=$VITE_GOOGLE_AUTH_ENABLED
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ENV VITE_API_KEY=$VITE_API_KEY
ENV VITE_DEBUG_API=$VITE_DEBUG_API

# Expose Vite dev server port
EXPOSE 5173

# Start Vite dev server (with proxy configured in vite.config.ts)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
